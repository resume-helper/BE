# ============================================================
# Atomic CV — 로컬 개발 환경변수 템플릿
# 사용법: cp .env.example .env 후 실제 값 입력
# 주의: .env 파일은 절대 커밋하지 않는다
# ============================================================

# Spring 프로파일 (로컬은 dev 고정)
SPRING_PROFILES_ACTIVE=dev

# ── Database (AWS RDS 직접 연결) ────────────────────────────
DB_URL=jdbc:mysql://<RDS_ENDPOINT>:3306/atomiccv_dev?serverTimezone=Asia/Seoul&characterEncoding=UTF-8
DB_USERNAME=<db_username>
DB_PASSWORD=<db_password>

# ── Redis (로컬 Docker) ─────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
